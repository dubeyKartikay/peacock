Output remove_filter.gif

Set Shell bash
Set FontSize 18
Set FontFamily "JetBrainsMono Nerd Font Mono"
Set Width 1800
Set Height 600
Set Padding 10

Type "peacock -f production.log"

Sleep 1s

Enter

Sleep 3s

Type "/"

Sleep 500ms

Type@500ms "payments"

Enter

Sleep 3s

Type "/"

Sleep 500ms

Type@500ms "error"

Enter

Sleep 3s

Backspace

Sleep 3s

Ctrl+C

Sleep 1s
